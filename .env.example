# Mull environment variables.
#
# Copy this to .env.local (gitignored) and fill in real values.
# Production deploys set these via Vercel project settings.

# ─── REQUIRED ─────────────────────────────────────────────────────
# Supabase project URL + anon key. Used by both server (SSR auth) and
# browser (client-side hydration of auth state). Anon key is safe to
# expose publicly — RLS policies on every table guard the actual rows.
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key. Bypasses RLS — never ship to the browser. Used by:
#   - /api/cron/* (aggregate operations across all users)
#   - /admin (dashboard aggregations)
#   - /api/account/delete + /export (cross-table cleanup that auth.uid()
#     RLS would partially block)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic API key. Used by:
#   - /api/dilemma/submit + /submit-archive (analysis + diagnosis)
#   - /api/diary/save (analysis + diagnosis)
#   - /api/exercises/reflect (analysis + diagnosis)
#   - /api/debate/generate + /me (philosopher dialogue generation)
#   - /api/account/retrospective (year-end essay)
# Each consumer falls back to "skip analysis" mode when this is unset,
# so the app still works without it — just without AI-generated text.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── CRON-RELATED ─────────────────────────────────────────────────
# Shared secret between Vercel cron scheduler and the /api/cron/* routes.
# Each cron route compares `Authorization: Bearer <CRON_SECRET>` against
# this; mismatch returns 401. WITHOUT THIS, every cron route hard-fails
# closed (returns 401 even to Vercel) — so crons don't run at all until
# you set this on both sides. Vercel's "Cron Jobs" UI lets you set the
# header per-cron; the same secret needs to be set in env vars too.
CRON_SECRET=<random 32+ char string>

# Email-sending (Resend). Used by:
#   - /api/account/welcome (one-time welcome email on first /account)
#   - /api/cron/dilemma-reminders (daily 9am-local prompt)
#   - /api/cron/streak-break (gentle nudge when streak breaks)
#   - /api/cron/weekly-digest (Sunday-morning weekly recap)
# When either is unset, all four routes fall back to dry-run mode:
# they log "would send to X" without actually emailing. Safe to leave
# unset in development.
EMAIL_PROVIDER_API_KEY=re_...
EMAIL_FROM=Mull <hello@mull.world>

# ─── OPTIONAL ─────────────────────────────────────────────────────
# Admin user IDs (comma-separated UUIDs). Members of this list get
# access to /admin and /account/curate. Unset = no admins.
ADMIN_USER_IDS=00000000-0000-0000-0000-000000000000,11111111-...

# Rate-limit salt. Used to hash IP addresses before storing in
# rate_limit_events (so logs don't leak raw IPs). Default is a
# placeholder; rotate before launch to invalidate any existing
# hashes computed under the default.
RATE_LIMIT_SALT=<random string>

# ─── STRIPE (BILLING — DRY-RUN MODE WHEN UNSET) ───────────────────
# When STRIPE_SECRET_KEY is unset, /billing/checkout returns a dry-run
# URL pointing at /billing/dry-run instead of a real Stripe Checkout
# session. Both /billing pages work without Stripe configured.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── CANONICAL SITE URL ───────────────────────────────────────────
# Used by /api/billing/checkout for success/cancel URLs. Defaults to
# https://mull.world if unset, so production doesn't strictly need
# this. Set on preview deploys if you want them to use their own URL.
# NEXT_PUBLIC_SITE_URL=https://mull.world
